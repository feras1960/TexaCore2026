{
  "name": "erpsystem-supabase",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --mode cloud",
    "dev:local": "node scripts/api-proxy.cjs & vite --port 5174 --mode selfhosted",
    "start:hybrid": "bash scripts/start-local-services.sh",
    "build": "vite build",
    "build:only": "vite build",
    "build:check": "tsc && vite build",
    "preview": "vite preview",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src/ --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src/ --ext ts,tsx --fix",
    "typecheck": "tsc --noEmit",
    "scan": "i18next-scanner --config i18next-scanner.config.cjs",
    "scan:accounting": "i18next-scanner --config i18next-scanner.accounting.config.cjs",
    "sync:translations": "node scripts/sync-translations.cjs",
    "check:translations": "node scripts/check-translations.cjs",
    "validate": "npm run typecheck && npm run lint && npm run check:translations",
    "prepare": "husky install || true",
    "pre-commit": "npm run validate",
    "types:supabase": "npx supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/supabase.ts",
    "dev:desktop": "VITE_IS_DESKTOP=true vite --port 5174",
    "build:installer": "vite build && rsync -a --delete dist/ texacore-installer/frontend/"
  },
