                    }
                ]
            ]
        },
        "📋 Format Data Reply": {
            "main": [
                [
                    {
                        "node": "📨 Send Data Reply",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "🤖 Gemini AI Reply": {
            "main": [
                [
                    {
                        "node": "📋 Format AI Reply",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "📋 Format AI Reply": {
            "main": [
                [
                    {
