<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Nexa Connect</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>nexa_connect</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- ═══════════════════════════════════════════════ -->
	<!-- Permission Usage Descriptions                   -->
	<!-- ═══════════════════════════════════════════════ -->

	<!-- 🎤 Microphone — Required for VoIP calls and Push-to-Talk -->
	<key>NSMicrophoneUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى الميكروفون لإجراء المكالمات الصوتية عبر الإنترنت واستخدام خاصية "اضغط للتحدث" (Push-to-Talk) مع فريقك.</string>

	<!-- 📇 Contacts — Required to sync and display contacts -->
	<key>NSContactsUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى جهات الاتصال لعرض أسماء المتصلين وتسهيل الاتصال المباشر بزملائك وعملائك من داخل التطبيق.</string>

	<!-- 📷 Camera — For video calls and sharing photos -->
	<key>NSCameraUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى الكاميرا لإجراء مكالمات الفيديو ومشاركة الصور والمستندات عبر المحادثات.</string>

	<!-- 🖼 Photo Library — For sharing media in chats -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى الصور لمشاركة الصور والملفات مع زملائك عبر المحادثات والقنوات.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>يحتاج NexaConnect لحفظ الصور والملفات المستلمة من المحادثات في ألبوم الصور.</string>

	<!-- 📍 Location — For location sharing in chats -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى موقعك لمشاركة الموقع مع زملائك عند الحاجة، مثل تحديد مواقع التسليم أو مكان التواجد.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى موقعك في الخلفية لاستقبال المكالمات الواردة وإرسال إشعارات الطوارئ عند الحاجة.</string>

	<!-- 🔔 Notifications -->
	<key>NSUserNotificationsUsageDescription</key>
	<string>يحتاج NexaConnect لإرسال إشعارات لتنبيهك بالمكالمات الواردة والرسائل الجديدة من فريقك.</string>

	<!-- 📞 CallKit — VoIP call integration -->
	<key>UIBackgroundModes</key>
	<array>
		<string>voip</string>
		<string>audio</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>

	<!-- 🗣 Speech Recognition -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى التعرف على الكلام لتحويل الرسائل الصوتية إلى نص مكتوب.</string>

	<!-- 📱 Local Network (for local SIP/PBX) -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>يحتاج NexaConnect للوصول إلى الشبكة المحلية للاتصال بالسنترال الداخلي (PBX) وإجراء المكالمات عبر شبكة الشركة.</string>

</dict>
</plist>
