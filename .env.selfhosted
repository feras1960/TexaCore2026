# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=texacore
POSTGRES_USER=texacore
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD_123!
DB_PORT=5432

# ── License ───────────────────────────────────────────────────
