LICENSE_KEY=LIC-2026-XXXXX-XXXXX
LICENSING_SERVER_URL=https://wzkklenfsaepegymfxfz.supabase.co/functions/v1

# ── Application ───────────────────────────────────────────────
APP_PORT=80
APP_VERSION=1.0.0
TEXACORE_IMAGE=ghcr.io/feras1960/texacore-web:latest

# ── Backup ────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
