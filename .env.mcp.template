# اختر أحد الخيارات التالية:

# ────────────────────────────────────────────────────────────────
# الخيار 1: مستخدم القراءة فقط (مُوصى به للأمان)
# ────────────────────────────────────────────────────────────────
SUPABASE_DB_URL=postgresql://ai_readonly:YOUR_PASSWORD_HERE@db.wzkklenfsaepegymfxfz.supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────────
# الخيار 2: المستخدم الرئيسي (postgres) - للتطوير فقط
# ────────────────────────────────────────────────────────────────
# SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD_HERE@db.wzkklenfsaepegymfxfz.supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────────
# الخيار 3: Connection Pooler (الأفضل للإنتاج)
# ────────────────────────────────────────────────────────────────
# SUPABASE_DB_URL=postgresql://ai_readonly:YOUR_PASSWORD_HERE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ────────────────────────────────────────────────────────────────
# معلومات المشروع
# ────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_REF=wzkklenfsaepegymfxfz
SUPABASE_PROJECT_URL=https://wzkklenfsaepegymfxfz.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ────────────────────────────────────────────────────────────────
# خيارات الاتصال (اختياري)
# ────────────────────────────────────────────────────────────────
PGDATABASE=postgres
PGHOST=db.wzkklenfsaepegymfxfz.supabase.co
PGPORT=5432
PGUSER=ai_readonly
PGPASSWORD=YOUR_PASSWORD_HERE

# ────────────────────────────────────────────────────────────────
# SSL (افتراضياً: true)
# ────────────────────────────────────────────────────────────────
PGSSLMODE=require

