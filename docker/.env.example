# ═══════════════════════════════════════════════
# TexaCore Desktop — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and customize the values
# NEVER commit .env to version control!

# ─── Ports ─────────────────────────────────────
API_EXTERNAL_PORT=54321
POSTGRES_PORT=54322

# ─── Database ──────────────────────────────────
POSTGRES_PASSWORD=texacore-local-super-secret

# ─── JWT (must be ≥32 characters) ──────────────
JWT_SECRET=texacore-jwt-secret-at-least-32-characters-long-change-me
JWT_EXPIRY=3600

# ─── Supabase Keys ────────────────────────────
# Generate these with: npx supabase-keys --jwt-secret "YOUR_JWT_SECRET"
# Or use the defaults for local development:
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WO_eo0y4lHl1pBdvVu_mkwMvO1s22qwpM3C0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ─── Realtime ──────────────────────────────────
SECRET_KEY_BASE=texacore-realtime-secret-key-base-at-least-64-characters-for-erlang-cookie-must-be-long
